{
  "name": "family-memory",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler pages dev dist --d1 DB=family-memory --r2 R2=family-memory --port 8788",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:api\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "wrangler pages dev dist --d1 DB=family-memory --r2 R2=family-memory",
    "db:migrate": "wrangler d1 execute family-memory --file=db/schema.sql",
    "db:seed": "wrangler d1 execute family-memory --file=db/seed.sql",
    "db:migrate:local": "wrangler d1 execute family-memory --local --file=db/schema.sql",
    "db:seed:local": "wrangler d1 execute family-memory --local --file=db/seed.sql",
    "db:setup:local": "npm run db:migrate:local && npm run db:seed:local",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.576.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wrangler": "^4.70.0"
  }
}
